# Relative path uses Vite proxy (recommended). Change only VITE_API_PROXY_TARGET below.
# Set to an absolute URL (e.g. http://192.168.1.5/nongsan-api) to bypass proxy.
VITE_API_BASE_URL=/nongsan-api

# Vite dev proxy target — this is the ONLY line most developers need to change.
# Set to your local XAMPP Apache origin (port 80 = no port needed).
# Example default (port 80):  http://localhost
# Example port 8080:          http://localhost:8080
# Example HTTPS:              https://localhost:4433
VITE_API_PROXY_TARGET=http://localhost

# Optional: force browser API origin directly (skip auto-detect, used by user section)
# Example: VITE_API_ORIGIN=http://localhost:8080
VITE_API_ORIGIN=

# Optional: extra local ports to probe automatically (comma-separated)
# Defaults: 8080,8000,8888
VITE_API_FALLBACK_PORTS=8080,8000,8888

# Backend (PHP API)
DB_HOST=localhost
DB_NAME=uxi
DB_USER=root
DB_PASSWORD=

# Public base URL used to build uploaded file URLs
APP_BASE_URL=http://localhost/nongsan-api
FRONTEND_ORIGIN=http://localhost:3000

# JWT signing key
JWT_SECRET=dev_only_change_me

# Payment
VNPAY_RETURN_URL=

# Mailer
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_EMAIL=no-reply@nongsan.com
MAIL_FROM_NAME=He Thong Nong San
MAIL_ENCRYPTION=tls
